module pca_core(
    input clk,
    input [7:0] x0,x1,x2,x3,x4,x5,x6,x7,
    output reg signed [15:0] y1,
    output reg signed [15:0] y2
);

// Example fixed weights (replace later with MATLAB PCA)
parameter signed [7:0] w1 [0:7] = '{2,3,1,2,1,2,1,3};
parameter signed [7:0] w2 [0:7] = '{1,1,2,1,3,1,2,1};

always @(posedge clk) begin
    y1 <= x0*w1[0] + x1*w1[1] + x2*w1[2] + x3*w1[3] +
          x4*w1[4] + x5*w1[5] + x6*w1[6] + x7*w1[7];

    y2 <= x0*w2[0] + x1*w2[1] + x2*w2[2] + x3*w2[3] +
          x4*w2[4] + x5*w2[5] + x6*w2[6] + x7*w2[7];
end

endmodule